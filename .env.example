# Render note:
# - If you paste values into the Render dashboard UI, do not include surrounding quotes.
# - If you use Render "Add from .env", valid .env syntax is fine.
# - This app uses environment variables, not Render Secret Files.

# Database - Supabase PostgreSQL
# Get from: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Auth
JWT_SECRET="generate-a-random-32-char-string"
TEACHER_KEY="long-random-teacher-registration-key"
ADMIN_KEY="long-random-admin-registration-key"
API_KEY_ENCRYPTION_KEY="base64-encoded-32-byte-key"
APP_BASE_URL="https://your-app.example.com"
CRON_SECRET="shared-secret-for-scheduled-jobs"

# Google Gemini
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.1-flash-lite"

# AI Provider — cloud (Gemini) vs local (Ollama-compatible), including the
# server URL, chat model, embedding model, auth mode, and num_ctx override,
# is configured live via Program Setup > AI Provider (admin UI), which
# writes to SystemConfig (ai_provider, ai_provider_url, ai_provider_model,
# ai_provider_embedding_model, ai_provider_auth_mode, ai_provider_num_ctx).
# The env vars below are fallbacks read only when the matching SystemConfig
# value is unset — they do NOT need to be set for normal operation.
# GEMINI_API_KEY                          # platform Gemini key fallback (see above)
# GEMINI_MODEL                            # Gemini chat model fallback (see above)
# AI_PROVIDER_API_KEY                     # local AI bearer-token fallback
# AI_PROVIDER_CLOUDFLARE_ACCESS_CLIENT_ID     # or CF_ACCESS_CLIENT_ID
# AI_PROVIDER_CLOUDFLARE_ACCESS_CLIENT_SECRET # or CF_ACCESS_CLIENT_SECRET
# AI_PROVIDER_EMBEDDING_MODEL="nomic-embed-text" # local embedding model fallback; must be a native 768-dim model

# Sage feature flags
# SAGE_AGENT_ENABLED="true"                  # default true (unset/anything but "false" enables); set "false" to disable Sage tool calls + server-driven slash commands
# SAGE_MEMORY_ENABLED="true"                 # default true; set "false" to disable extraction + retrieval (Mem0 ADD-only pattern)
# SAGE_MEMORY_DUP_DISTANCE="0.08"            # cosine-distance dedupe cutoff for semantic memory (0,1]
# SAGE_RAG_ENABLED="true"                    # default true; set "false"/"0"/"no"/"off" to disable hybrid doc RAG
# SAGE_RAG_MODE="hybrid"                     # "hybrid" (default) | "keyword" — operational kill switch back to legacy scoring
# SAGE_RAG_MAX_DISTANCE="0.55"               # cosine-distance cutoff for semantic-only (no FTS hit) matches
# SAGE_RAG_MIN_SCORE_RATIO="0"               # relative RRF score cutoff vs top result, [0,1)
# SAGE_RAG_DISTANCE_MARGIN="0.04"            # relative distance margin vs closest match, [0,1]; 0 disables
# SAGE_RAG_ABSTAIN_DISTANCE="1"              # abstention floor (0,2]; default 1 leaves the gate effectively off
# SAGE_WAGER_DIAGNOSIS_ENABLED="false"       # default false; set "true" to enable wager-resolution diagnosis insights

# File storage — Supabase Storage (S3-compatible)
# Get from: Supabase Dashboard > Storage > S3 Connection
STORAGE_ENDPOINT="https://[YOUR-PROJECT-REF].supabase.co/storage/v1/s3"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="uploads"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# Legacy: Cloudflare R2 (still supported if STORAGE_* vars are not set)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY=""
# R2_SECRET_KEY=""
# R2_BUCKET_NAME=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# SMS delivery — Twilio (optional — SMS notifications disabled when not set)
# Get from: twilio.com/console
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""  # E.164 format, e.g. +12125551234

# Password reset email (required for self-serve recovery)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Visionquest <no-reply@example.com>"

# Error tracking (optional — Sentry)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""  # only needed for source map upload in CI

# Logging
# LOG_LEVEL="info"  # debug | info | warn | error

# Database connection pool (optional — defaults if unset)
# DB_POOL_SIZE="10"
# DB_POOL_TIMEOUT="10"  # seconds

# Testing / local only — disable rate limits + token quotas for smoke tests.
# Never set in production.
# VISIONQUEST_DISABLE_RATE_LIMITS="true"

# Job board scrapers (optional — each provider is enabled when its keys are present)
# Adzuna — adzuna.com/developer/api-docs
# ADZUNA_APP_ID=""
# ADZUNA_APP_KEY=""
# JSearch (RapidAPI) — rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# JSEARCH_API_KEY=""
# USAJobs — developer.usajobs.gov
# USAJOBS_API_KEY=""
# USAJOBS_EMAIL=""  # required User-Agent contact per USAJobs ToS

# CareerOneStop / National Labor Exchange (free, royalty-free). Register at
# https://www.careeronestop.org/Developers/WebAPI/registration.aspx
COS_USER_ID=
COS_API_TOKEN=

# Notes:
# - Generate API_KEY_ENCRYPTION_KEY with:
#   openssl rand -base64 32
# - Generate TEACHER_KEY with:
#   openssl rand -base64 32 | tr -d '\n'
# - GOOGLE_REDIRECT_URI can be omitted for local development, but the matching
#   callback URL still needs to be whitelisted in Google Cloud for deployment.
# - APP_BASE_URL should match the public URL used in password reset emails.
# - CRON_SECRET protects internal scheduled routes like appointment reminders.
# - For the Render dashboard specifically, paste raw values such as `https://your-app.onrender.com`
#   and `postgresql://...` without wrapping them in quotes.

# --- Outbound automation webhooks (experiment) ---
# Notify an external automation platform (self-hosted n8n preferred; Make/Zapier
# possible) on verified domain events, so a deterministic workflow can fan them
# out to email/SMS/Slack/reporting. OFF unless AUTOMATIONS_ENABLED=true.
# Payloads are PII-minimal (IDs + a link, never student content) and HMAC-signed.
AUTOMATIONS_ENABLED=false
AUTOMATION_WEBHOOK_URL=
# Used to HMAC-sign the body (X-VisionQuest-Signature: sha256=...). Generate a
# strong random value and configure the same secret on the receiving workflow.
AUTOMATION_WEBHOOK_SECRET=
