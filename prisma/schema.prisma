// =============================================================================
// Program Documents
// Stores program-level PDFs, forms, and reference materials in Supabase Storage.
// These are NOT student-specific — they belong to the program itself.
// =============================================================================

model ProgramDocument {
  id String @id @default(cuid())

  // --- Display Info ---
  title       String // Human-readable name, e.g. "IC3 Study Guide"
  description String? @db.Text // Optional summary for Sage and UI tooltips

  // --- Storage ---
  storageKey String @unique // Supabase Storage path, e.g. "documents/lms/ic3-study-guide.pdf"
  mimeType   String @default("application/pdf")
  sizeBytes  Int?

  // --- Classification ---
  // Document category determines folder and display context
  category ProgramDocCategory
  // Who can see/access this document
  audience ProgramDocAudience @default(BOTH)

  // --- Linking to Certifications & Platforms ---
  // Optional: link this document to a specific certification ID (from certifications.ts)
  certificationId String? // e.g. "ic3", "mos-word", "workkeys-ncrc"
  // Optional: link this document to a specific platform ID (from platforms.ts)
  platformId      String? // e.g. "gmetrix-and-learnkey", "edgenuity"

  // --- Sage AI Context ---
  // If true, this document's description is injected into Sage's knowledge base
  usedBySage      Boolean   @default(false)
  // Short text summary Sage can read (avoids loading full PDF into prompt)
  sageContextNote String?   @db.Text
  fileModifiedAt  DateTime? // Filesystem mtime at ingestion — for change detection

  // --- Semantic Retrieval (Phase 1 — hybrid RAG) ---
  // gemini-embedding-001 @ 768 dims over `title + sageContextNote`.
  // Read/written only via $queryRaw/$executeRaw (Prisma Unsupported type).
  // Manual SQL objects NOT representable here (see migrations):
  //   - HNSW index ProgramDocument_embedding_hnsw_idx (vector_cosine_ops)
  //   - GIN expression index ProgramDocument_fts_idx on
  //     to_tsvector('english', title || ' ' || coalesce(sageContextNote, ''))
  //   - Function visionquest.sage_hybrid_search(...) — RRF hybrid retrieval
  embedding Unsupported("vector(768)")?
  chunks    DocumentChunk[]

  // --- Metadata ---
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  uploadedBy String? // studentId of teacher who uploaded
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category, audience, isActive])
  @@index([certificationId])
  @@index([platformId])
  @@index([usedBySage, isActive])
  @@schema("visionquest")
}

// Chunked bodies of extractable-text ProgramDocuments (~512-token chunks,
// 50-token overlap) embedded for semantic retrieval. Scanned/image docs have
// no chunks — their doc-level embedding (title + sageContextNote) suffices.
// Manual SQL (see migrations): HNSW index DocumentChunk_embedding_hnsw_idx,
// RLS policies mirroring program_document_read/write.
model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String   @db.Text
  embedding  Unsupported("vector(768)")?
  tokenCount   Int?
  pageNumber   Int?
  sectionTitle String?
  // fts is a GENERATED tsvector managed in raw SQL (see add_chunk_provenance
  // migration). Prisma cannot express GENERATED columns; declared Unsupported
  // so it stays out of drift detection — do NOT accept a migrate-dev drop diff.
  fts          Unsupported("tsvector")?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document ProgramDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@schema("visionquest")
}

// Durable Sage memory (Phase 2). One row = one fact about a subject.
// kind: episodic (events/sessions) | semantic (stable facts/preferences) |
// procedural (what works when coaching this subject).
// Temporal validity (Graphiti pattern): active rows have validTo = NULL;
// superseded/expired rows keep history. sourceHash dedupes re-extraction
// (TEKTON pattern): sha256 over normalized subject + content.
// Manual SQL (see migration): HNSW index SageMemory_embedding_hnsw_idx,
// partial unique index on (subjectType, subjectId, sourceHash) WHERE
// "validTo" IS NULL, RLS (students read/insert own rows only).
model SageMemory {
  id          String    @id @default(cuid())
  subjectType String // student | teacher | class | program
  subjectId   String
  kind        String // episodic | semantic | procedural
  content     String    @db.Text
  embedding   Unsupported("vector(768)")?
  category    String // goal | preference | circumstance | skill | coaching | progress | other
  confidence  Float     @default(0.7)
  validFrom   DateTime  @default(now())
  validTo     DateTime?
  sourceType  String // conversation | operation | manual
  sourceId    String?
  sourceHash  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  edgesFrom SageMemoryEdge[] @relation("MemoryEdgeFrom")
  edgesTo   SageMemoryEdge[] @relation("MemoryEdgeTo")

  @@index([subjectType, subjectId, validTo])
  @@index([sourceType, sourceId])
  @@schema("visionquest")
}

// Typed relationships between memories with evidence (TEKTON pattern).
model SageMemoryEdge {
  id         String   @id @default(cuid())
  fromId     String
  toId       String
  predicate  String // depends_on | blocks | supersedes | relates_to | evidenced_by
  evidence   String   @db.Text
  confidence Float    @default(0.7)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  from SageMemory @relation("MemoryEdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   SageMemory @relation("MemoryEdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
  @@schema("visionquest")
}

// Recorded student consent (Phase 3). Active consent = grantedAt set and
// revokedAt null for the scope. History preserved: revocation closes the row;
// re-granting creates a new one. scope: cloud_file_processing (Gemini Files
// API may process this student's uploaded documents).
model ConsentRecord {
  id         String    @id @default(cuid())
  studentId  String
  scope      String
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?
  recordedBy String // student id (self-service) or staff id
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, scope, revokedAt])
  @@schema("visionquest")
}

// Operation ledger: every Sage write action records here (Phase 3 write
// tools consume this). Deterministic ids ("op-{timestamp}-{slug}") make
// repeated tool invocations idempotent and auditable.
model SageOperation {
  id            String   @id
  actorType     String // student | teacher | admin | system
  actorId       String
  toolName      String
  status        String // proposed | confirmed | executed | failed | rejected
  payload       Json
  resultSummary String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([actorType, actorId])
  @@index([toolName, status])
  @@schema("visionquest")
}

enum ProgramDocCategory {
