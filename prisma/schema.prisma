generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["visionquest"]
}

model Student {
  id             String   @id @default(cuid())
  studentId      String   @unique
  displayName    String
  passwordHash   String
  email          String?  @unique
  geminiApiKey   String?
  credlyUsername String?
  role           String   @default("student")
  isActive       Boolean  @default(true)
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversations           Conversation[]
  goals                   Goal[]
  progression             Progression?
  files                   FileUpload[]
  orientationProgress     OrientationProgress[]
  certifications          Certification[]
  portfolioItems          PortfolioItem[]
  resumeData              ResumeData?
  passwordResetTokens     PasswordResetToken[]
  securityQuestionAnswers SecurityQuestionAnswer[]
  appointments            Appointment[]            @relation("StudentAppointments")
  advisorAppointments     Appointment[]            @relation("AdvisorAppointments")
  createdClasses          SpokesClass[]            @relation("CreatedClasses")
  instructedClasses       SpokesClassInstructor[]  @relation("ClassInstructors")
  classEnrollments        StudentClassEnrollment[] @relation("ClassEnrollments")
  assignedTasks           StudentTask[]            @relation("AssignedTasks")
  createdTasks            StudentTask[]            @relation("CreatedTasks")
  caseNotes               CaseNote[]               @relation("StudentCaseNotes")
  authoredNotes           CaseNote[]               @relation("AuthoredCaseNotes")
  alerts                  StudentAlert[]
  availabilityBlocks      AdvisorAvailability[]    @relation("AdvisorAvailability")
  createdOpportunities    Opportunity[]            @relation("CreatedOpportunities")
  applications            Application[]
  createdEvents           CareerEvent[]            @relation("CreatedEvents")
  eventRegistrations      EventRegistration[]
  publicCredentialPage    PublicCredentialPage?
  spokesRecord            SpokesRecord?
  notifications           Notification[]
  formSubmissions         FormSubmission[]
  visionBoardItems        VisionBoardItem[]
  goalResourceLinks       GoalResourceLink[]       @relation("StudentGoalResourceLinks")
  assignedGoalLinks       GoalResourceLink[]       @relation("AssignedGoalResourceLinks")
  progressionEvents       ProgressionEvent[]
  careerDiscovery         CareerDiscovery?

  @@schema("visionquest")
}

model Conversation {
  id        String   @id @default(cuid())
  studentId String
  module    String
  stage     String
  title     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@schema("visionquest")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  metadata       String?  @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@schema("visionquest")
}

model Goal {
  id              String   @id @default(cuid())
  studentId       String
  level           String
  parentId        String?
  content         String   @db.Text
  status          String   @default("active")
  sourceMessageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student       Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent        Goal?              @relation("GoalHierarchy", fields: [parentId], references: [id])
  children      Goal[]             @relation("GoalHierarchy")
  resourceLinks GoalResourceLink[]

  @@schema("visionquest")
}

model Progression {
  id        String @id @default(cuid())
  studentId String @unique
  state     String
  version   Int    @default(0)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@schema("visionquest")
}

model ProgressionEvent {
  id         String   @id @default(cuid())
  studentId  String
  eventType  String
  sourceType String
  sourceId   String
  xp         Int
  metadata   String?  @db.Text
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventType, sourceType, sourceId])
  @@index([studentId, occurredAt])
  @@index([eventType, occurredAt])
  @@schema("visionquest")
}

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String
  payload     String    @db.Text
  status      String    @default("pending") // pending, processing, completed, failed
  dedupeKey   String?
  attempts    Int       @default(0)
  error       String?   @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
  @@index([dedupeKey, status])
  @@schema("visionquest")
}

model OrientationItem {
  id          String   @id @default(cuid())
  label       String
  description String?  @db.Text
  section     String?
  sortOrder   Int      @default(0)
  required    Boolean  @default(true)
  createdAt   DateTime @default(now())

  progress OrientationProgress[]

  @@schema("visionquest")
}

model OrientationProgress {
  id          String    @id @default(cuid())
  studentId   String
  itemId      String
  completed   Boolean   @default(false)
  completedAt DateTime?

  student Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item    OrientationItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([studentId, itemId])
  @@schema("visionquest")
}

model LmsLink {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  url         String
  category    String
  icon        String?
  sortOrder   Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("visionquest")
}

model SpokesRecord {
  id                              String    @id @default(cuid())
  studentId                       String?   @unique
  firstName                       String
  lastName                        String
  referralEmail                   String?
  county                          String?
  householdType                   String?
  requiredParticipationHours      Int?
  referralDate                    DateTime? @db.Date
  status                          String    @default("referred")
  enrolledAt                      DateTime? @db.Date
  exitDate                        DateTime? @db.Date
  gender                          String?
  birthDate                       DateTime? @db.Date
  race                            String?
  ethnicity                       String?
  barriersOnEntry                 String[]  @default([])
  barriersRemaining               String[]  @default([])
  jobRetentionStudent             Boolean   @default(false)
  tabeDate                        DateTime? @db.Date
  educationalLevel                String?
  documentedAcademicAchievementAt DateTime? @db.Date
  highSchoolEquivalencyAt         DateTime? @db.Date
  familySurveyOfferedAt           DateTime? @db.Date
  postSecondaryEnteredAt          DateTime? @db.Date
  postSecondaryProgram            String?
  unsubsidizedEmploymentAt        DateTime? @db.Date
  employerName                    String?
  hourlyWage                      Float?
  nonCompleterAt                  DateTime? @db.Date
  nonCompleterReason              String?   @db.Text
  notes                           String?   @db.Text
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  student             Student?                   @relation(fields: [studentId], references: [id], onDelete: SetNull)
  checklistProgress   SpokesChecklistProgress[]
  moduleProgress      SpokesModuleProgress[]
  employmentFollowUps SpokesEmploymentFollowUp[]

  @@index([status, referralDate])
  @@index([county, status])
  @@schema("visionquest")
}

model SpokesChecklistTemplate {
  id          String   @id @default(cuid())
  label       String
  description String?  @db.Text
  category    String
  sortOrder   Int      @default(0)
  required    Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress SpokesChecklistProgress[]

  @@index([category, sortOrder])
  @@schema("visionquest")
}

model SpokesChecklistProgress {
  id          String    @id @default(cuid())
  recordId    String
  templateId  String
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  record   SpokesRecord            @relation(fields: [recordId], references: [id], onDelete: Cascade)
  template SpokesChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([recordId, templateId])
  @@index([recordId, completed])
  @@schema("visionquest")
}

model SpokesModuleTemplate {
  id          String   @id @default(cuid())
  label       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  required    Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress SpokesModuleProgress[]

  @@index([sortOrder])
  @@schema("visionquest")
}

model SpokesModuleProgress {
  id          String   @id @default(cuid())
  recordId    String
  templateId  String
  completedAt DateTime
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  record   SpokesRecord         @relation(fields: [recordId], references: [id], onDelete: Cascade)
  template SpokesModuleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([recordId, templateId])
  @@index([recordId, completedAt])
  @@schema("visionquest")
}

model SpokesEmploymentFollowUp {
  id               String   @id @default(cuid())
  recordId         String
  checkpointMonths Int
  status           String
  checkedAt        DateTime @db.Date
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  record SpokesRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@unique([recordId, checkpointMonths])
  @@index([recordId, checkedAt])
  @@schema("visionquest")
}

model Certification {
  id          String    @id @default(cuid())
  studentId   String
  certType    String    @default("ready-to-work")
  status      String    @default("in_progress")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requirements CertRequirement[]

  @@unique([studentId, certType])
  @@schema("visionquest")
}

model CertRequirement {
  id              String    @id @default(cuid())
  certificationId String
  templateId      String
  completed       Boolean   @default(false)
  completedAt     DateTime?
  verifiedBy      String?
  verifiedAt      DateTime?
  fileId          String?
  notes           String?   @db.Text

  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  template      CertTemplate  @relation(fields: [templateId], references: [id])

  @@schema("visionquest")
}

model CertTemplate {
  id          String  @id @default(cuid())
  certType    String  @default("ready-to-work")
  label       String
  description String? @db.Text
  url         String?
  sortOrder   Int     @default(0)
  required    Boolean @default(true)
  needsFile   Boolean @default(false)
  needsVerify Boolean @default(true)

  requirements CertRequirement[]

  @@schema("visionquest")
}

model PortfolioItem {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String?  @db.Text
  type        String   @default("project")
  fileId      String?
  url         String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@schema("visionquest")
}

model ResumeData {
  id        String @id @default(cuid())
  studentId String @unique
  data      String @db.Text

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@schema("visionquest")
}

model FileUpload {
  id         String   @id @default(cuid())
  studentId  String
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  category   String   @default("general")
  uploadedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@schema("visionquest")
}

model SpokesClass {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  status      String    @default("active")
  description String?   @db.Text
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  archivedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy   Student?                 @relation("CreatedClasses", fields: [createdById], references: [id], onDelete: SetNull)
  instructors SpokesClassInstructor[]
  enrollments StudentClassEnrollment[]

  @@index([status, name])
  @@schema("visionquest")
}

model SpokesClassInstructor {
  classId      String
  instructorId String
  assignedAt   DateTime @default(now())

  class      SpokesClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  instructor Student     @relation("ClassInstructors", fields: [instructorId], references: [id], onDelete: Cascade)

  @@id([classId, instructorId])
  @@index([instructorId])
  @@schema("visionquest")
}

model StudentClassEnrollment {
  id            String    @id @default(cuid())
  classId       String
  studentId     String
  status        String    @default("active")
  enrolledAt    DateTime  @default(now())
  archivedAt    DateTime?
  archiveReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  class   SpokesClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  student Student     @relation("ClassEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([studentId, status])
  @@index([classId, status])
  @@schema("visionquest")
}

model Appointment {
  id                 String    @id @default(cuid())
  studentId          String
  advisorId          String
  title              String
  description        String?   @db.Text
  startsAt           DateTime
  endsAt             DateTime
  status             String    @default("scheduled")
  locationType       String    @default("virtual")
  locationLabel      String?
  meetingUrl         String?
  notes              String?   @db.Text
  followUpRequired   Boolean   @default(false)
  bookingSource      String    @default("teacher")
  confirmationSentAt DateTime?
  reminderSentAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  student Student       @relation("StudentAppointments", fields: [studentId], references: [id], onDelete: Cascade)
  advisor Student       @relation("AdvisorAppointments", fields: [advisorId], references: [id], onDelete: Cascade)
  tasks   StudentTask[]

  @@index([studentId, startsAt])
  @@index([advisorId, startsAt])
  @@index([status, startsAt])
  @@schema("visionquest")
}

model AdvisorAvailability {
  id            String   @id @default(cuid())
  advisorId     String
  weekday       Int
  startMinutes  Int
  endMinutes    Int
  slotMinutes   Int      @default(30)
  locationType  String   @default("virtual")
  locationLabel String?
  meetingUrl    String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  advisor Student @relation("AdvisorAvailability", fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, weekday, active])
  @@schema("visionquest")
}

model StudentTask {
  id            String    @id @default(cuid())
  studentId     String
  createdById   String
  appointmentId String?
  title         String
  description   String?   @db.Text
  dueAt         DateTime?
  status        String    @default("open")
  priority      String    @default("normal")
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student     Student      @relation("AssignedTasks", fields: [studentId], references: [id], onDelete: Cascade)
  createdBy   Student      @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([studentId, status, dueAt])
  @@index([createdById, createdAt])
  @@schema("visionquest")
}

model CaseNote {
  id         String   @id @default(cuid())
  studentId  String
  authorId   String
  category   String   @default("general")
  body       String   @db.Text
  visibility String   @default("teacher")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student Student @relation("StudentCaseNotes", fields: [studentId], references: [id], onDelete: Cascade)
  author  Student @relation("AuthoredCaseNotes", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt(sort: Desc)])
  @@schema("visionquest")
}

model StudentAlert {
  id           String    @id @default(cuid())
  studentId    String
  alertKey     String    @unique
  type         String
  severity     String    @default("medium")
  status       String    @default("open") // open, snoozed, resolved, dismissed
  title        String
  summary      String    @db.Text
  sourceType   String?
  sourceId     String?
  detectedAt   DateTime  @default(now())
  resolvedAt   DateTime?
  snoozedUntil DateTime? // Manual snooze: alert hidden until this time
  snoozedBy    String? // Teacher ID who snoozed
  dismissedAt  DateTime? // Manual dismiss: soft delete by teacher
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status, detectedAt(sort: Desc)])
  @@index([status, severity, detectedAt(sort: Desc)])
  @@schema("visionquest")
}

model Opportunity {
  id          String    @id @default(cuid())
  title       String
  company     String
  type        String    @default("job")
  location    String?
  url         String?
  description String?   @db.Text
  status      String    @default("open")
  deadline    DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy    Student?      @relation("CreatedOpportunities", fields: [createdById], references: [id], onDelete: SetNull)
  applications Application[]

  @@index([status, deadline])
  @@schema("visionquest")
}

model Application {
  id            String    @id @default(cuid())
  studentId     String
  opportunityId String
  status        String    @default("saved")
  notes         String?   @db.Text
  resumeFileId  String?
  appliedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([studentId, opportunityId])
  @@index([studentId, status])
  @@schema("visionquest")
}

model CareerEvent {
  id                   String   @id @default(cuid())
  title                String
  description          String?  @db.Text
  startsAt             DateTime
  endsAt               DateTime
  location             String?
  virtualUrl           String?
  capacity             Int?
  registrationRequired Boolean  @default(true)
  status               String   @default("scheduled")
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  createdBy     Student?            @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: SetNull)
  registrations EventRegistration[]

  @@index([status, startsAt])
  @@schema("visionquest")
}

model EventRegistration {
  id           String   @id @default(cuid())
  studentId    String
  eventId      String
  status       String   @default("registered")
  registeredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  event   CareerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventId])
  @@index([studentId, status])
  @@schema("visionquest")
}

model PublicCredentialPage {
  id        String   @id @default(cuid())
  studentId String   @unique
  slug      String   @unique
  headline  String?
  summary   String?  @db.Text
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@schema("visionquest")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  studentId String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, expiresAt])
  @@schema("visionquest")
}

model SecurityQuestionAnswer {
  id          String   @id @default(cuid())
  studentId   String
  questionKey String
  answerHash  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, questionKey])
  @@index([studentId])
  @@schema("visionquest")
}

model Notification {
  id        String    @id @default(cuid())
  studentId String
  type      String
  title     String
  body      String?   @db.Text
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, read, createdAt(sort: Desc)])
  @@schema("visionquest")
}

model RateLimitEntry {
  key       String   @id
  count     Int      @default(0)
  resetTime DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetTime])
  @@schema("visionquest")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  targetType String
  targetId   String?
  summary    String?
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@schema("visionquest")
}

model FormSubmission {
  id         String    @id @default(cuid())
  studentId  String
  formId     String
  fileId     String
  status     String    @default("pending")
  reviewedBy String?
  reviewedAt DateTime?
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, formId])
  @@index([studentId, status])
  @@schema("visionquest")
}

// =============================================================================
// Program Documents
// Stores program-level PDFs, forms, and reference materials in Supabase Storage.
// These are NOT student-specific — they belong to the program itself.
// =============================================================================

model ProgramDocument {
  id String @id @default(cuid())

  // --- Display Info ---
  title       String // Human-readable name, e.g. "IC3 Study Guide"
  description String? @db.Text // Optional summary for Sage and UI tooltips

  // --- Storage ---
  storageKey String @unique // Supabase Storage path, e.g. "documents/lms/ic3-study-guide.pdf"
  mimeType   String @default("application/pdf")
  sizeBytes  Int?

  // --- Classification ---
  // Document category determines folder and display context
  category ProgramDocCategory
  // Who can see/access this document
  audience ProgramDocAudience @default(BOTH)

  // --- Linking to Certifications & Platforms ---
  // Optional: link this document to a specific certification ID (from certifications.ts)
  certificationId String? // e.g. "ic3", "mos-word", "workkeys-ncrc"
  // Optional: link this document to a specific platform ID (from platforms.ts)
  platformId      String? // e.g. "gmetrix-and-learnkey", "edgenuity"

  // --- Sage AI Context ---
  // If true, this document's description is injected into Sage's knowledge base
  usedBySage      Boolean @default(false)
  // Short text summary Sage can read (avoids loading full PDF into prompt)
  sageContextNote String? @db.Text

  // --- Metadata ---
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  uploadedBy String? // studentId of teacher who uploaded
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category, audience, isActive])
  @@index([certificationId])
  @@index([platformId])
  @@index([usedBySage, isActive])
  @@schema("visionquest")
}

enum ProgramDocCategory {
  // Student-facing
  ORIENTATION // New student onboarding forms and guides
  STUDENT_REFERRAL // DOHS / WV Works referral forms
  STUDENT_RESOURCE // General student handouts and resources

  // Teacher-facing
  TEACHER_GUIDE // Instructor guides and admin resources
  TEACHER_LMS_SUPPORT // Helps teachers understand platforms they aren't familiar with

  // LMS & Certifications
  LMS_PLATFORM_GUIDE // Platform-specific setup and how-to guides
  CERTIFICATION_INFO // Exam objectives, study guides, prerequisites
  CERTIFICATION_PREREQ // Prerequisite chains for complex certifications

  // Program Admin
  DOHS_FORM // DFA-TS-12, DFA-WVW-70, etc.
  PROGRAM_POLICY // Dress code, AUP, confidentiality, non-discrimination
  READY_TO_WORK // Module records, attendance verification, benchmarks

  // Sage Knowledge Base
  SAGE_CONTEXT // Raw context documents loaded into Sage's AI grounding

  // Presentations
  PRESENTATION // PowerPoints converted to PDF for display

  @@schema("visionquest")
}

enum ProgramDocAudience {
  STUDENT // Visible only to students
  TEACHER // Visible only to teachers/admins
  BOTH // Visible to everyone

  @@schema("visionquest")
}

model VisionBoardItem {
  id        String   @id @default(cuid())
  studentId String
  type      String
  content   String?  @db.Text
  fileId    String?
  goalId    String?
  posX      Float    @default(50)
  posY      Float    @default(50)
  width     Float    @default(20)
  rotation  Float    @default(0)
  color     String?
  pinColor  String   @default("red")
  zIndex    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@schema("visionquest")
}

model GoalResourceLink {
  id           String    @id @default(cuid())
  goalId       String
  studentId    String
  resourceType String
  resourceId   String
  title        String
  description  String?   @db.Text
  url          String?
  linkType     String    @default("assigned")
  status       String    @default("assigned")
  dueAt        DateTime?
  assignedById String?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  goal       Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  student    Student  @relation("StudentGoalResourceLinks", fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy Student? @relation("AssignedGoalResourceLinks", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([goalId, resourceType, resourceId, linkType])
  @@index([goalId, linkType, status])
  @@index([studentId, status])
  @@schema("visionquest")
}

model CareerDiscovery {
  id                 String    @id @default(cuid())
  studentId          String    @unique
  status             String    @default("in_progress") // in_progress | complete
  interests          String?   @db.Text
  strengths          String?   @db.Text
  subjects           String?   @db.Text
  problems           String?   @db.Text
  values             String?   @db.Text
  circumstances      String?   @db.Text
  clusterScores      String?   @db.Text
  topClusters        String[]  @default([])
  sageSummary        String?   @db.Text
  riasecScores       String?   @db.Text // JSON: {realistic, investigative, artistic, social, enterprising, conventional}
  hollandCode        String? // e.g., "SEC"
  nationalClusters   String?   @db.Text // JSON: [{cluster_name, score, spokes_mapping}]
  transferableSkills String?   @db.Text // JSON: [{skill, category, evidence}]
  workValues         String?   @db.Text // JSON: [{value, importance}]
  assessmentSummary  String?   @db.Text // 3-5 sentence instructor-facing summary
  conversationId     String?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@schema("visionquest")
}
