// =============================================================================
// RBAC — Role-Based Access Control
// Three-table design: Role → RolePermission → Permission
// Replaces hardcoded role-string comparisons with granular, runtime-editable
// permission checks backed by the database.
// =============================================================================

model Role {
  id             String   @id @default(cuid())
  name           String   @unique // "student", "teacher", "admin", "program_admin", "observer"
  displayName    String
  hierarchyLevel Int // 1=highest trust (super_admin), 4=lowest (student)
  description    String?
  isSystem       Boolean  @default(false) // System roles can't be deleted
  createdAt      DateTime @default(now())

  permissions RolePermission[]

  @@schema("visionquest")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // "goals.create", "goals.read.own", "sage.chat", etc.
  namespace   String // "goals", "sage", "admin", etc.
  displayName String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([namespace])
  @@schema("visionquest")
}

model RolePermission {
  id           String  @id @default(cuid())
  roleId       String
  permissionId String
  granted      Boolean @default(true) // true=allowed, false=explicitly denied

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@schema("visionquest")
}

// =============================================================================
// Regional Coordinator workspace (Phase 5)
// Regions aggregate classes for funder reporting and oversight. Coordinators
// are assigned to one or more regions and see rollup-level data for those
// regions only (no direct student/class management — that remains teacher-only).
// Grant goals track funder targets per region / programType / metric / period
// with actuals derived at query time from the underlying data (enrollments,
// certifications, placements).
// =============================================================================

model Region {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?  @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coordinators RegionCoordinator[]
  classes      SpokesClass[]
  grantGoals   GrantGoal[]

  @@index([status, name])
  @@schema("visionquest")
}

model RegionCoordinator {
  regionId      String
  coordinatorId String
  assignedAt    DateTime @default(now())

  region      Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  coordinator Student @relation(fields: [coordinatorId], references: [id], onDelete: Cascade)

  @@id([regionId, coordinatorId])
  @@index([coordinatorId])
  @@schema("visionquest")
}

model GrantGoal {
  id          String   @id @default(cuid())
  regionId    String
  programType String // "spokes" | "adult_ed" | "ietp" | "all"
  metric      String // enrollments | certifications | placements | ged_earned | custom
  targetValue Float
  periodStart DateTime
  periodEnd   DateTime
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([regionId, periodStart])
  @@index([metric, periodStart])
  @@schema("visionquest")
}
