/prisma/dev.db
/prisma/dev.db-journal

# reference documents (large PDFs)
/SPOKES Handbook/
/content/
/docs-upload/

# Claude Code — personal overrides (gitignored per best practices)
CLAUDE.local.md
.claude/settings.local.json

# Generated artifacts (screenshots, audit reports)
/artifacts/

# Temp files
tmp_*.txt

# Old backup dirs (safe to delete)
_old_CLAUDE.md/
_old_CLAUDE.local.md/
_old_MEMORY.md

# Agent tooling and session state
.remember/
.superpowers/
.worktrees/

# Test artifacts
playwright-report/
test-results/

